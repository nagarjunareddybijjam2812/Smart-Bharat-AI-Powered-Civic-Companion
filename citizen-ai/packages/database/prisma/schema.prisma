// CitizenAI — Complete Prisma Schema
// PostgreSQL + pgvector for AI embeddings

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearch"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), pg_trgm, unaccent]
}

// ==========================================
// ENUMS
// ==========================================

enum UserRole {
  CITIZEN
  OFFICER
  ADMIN
  SUPER_ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ADDITIONAL_INFO_REQUIRED
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum ComplaintStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  ESCALATED
  RESOLVED
  CLOSED
  REJECTED
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DocumentType {
  AADHAAR
  PAN
  PASSPORT
  DRIVING_LICENSE
  VOTER_ID
  BIRTH_CERTIFICATE
  INCOME_CERTIFICATE
  CASTE_CERTIFICATE
  DOMICILE_CERTIFICATE
  PROPERTY_DOCUMENT
  UTILITY_BILL
  PHOTOGRAPH
  SIGNATURE
  OTHER
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum NotificationType {
  SYSTEM
  APPLICATION_UPDATE
  COMPLAINT_UPDATE
  DOCUMENT_VERIFICATION
  SCHEME_ALERT
  EMERGENCY
  CHAT_MESSAGE
  REMINDER
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
  WHATSAPP
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  OFFICER
}

enum ServiceCategory {
  REVENUE
  HEALTH
  EDUCATION
  TRANSPORT
  HOUSING
  SOCIAL_WELFARE
  EMPLOYMENT
  AGRICULTURE
  WATER_SANITATION
  ELECTRICITY
  POLICE
  JUDICIARY
  TAXATION
  PASSPORT_VISA
  CIVIL_REGISTRATION
  ENVIRONMENT
  MUNICIPAL
  OTHER
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  APPROVE
  REJECT
  ESCALATE
}

// ==========================================
// USERS & AUTH
// ==========================================

model User {
  id              String    @id @default(cuid())
  email           String?   @unique
  phone           String?   @unique
  passwordHash    String?
  role            UserRole  @default(CITIZEN)
  isActive        Boolean   @default(true)
  isEmailVerified Boolean   @default(false)
  isPhoneVerified Boolean   @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  profile               UserProfile?
  oauthAccounts         OAuthAccount[]
  applications          Application[]
  complaints            Complaint[]
  documents             Document[]
  notifications         Notification[]
  conversations         Conversation[]
  aiSessions            AISession[]
  feedbacks             Feedback[]
  auditLogs             AuditLog[]
  assignedComplaints    Complaint[]           @relation("OfficerComplaints")
  departmentOfficer     DepartmentOfficer?
  notificationPrefs     NotificationPreference[]
  savedServices         SavedService[]
  activityLogs          ActivityLog[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@map("users")
}

model UserProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  firstName    String
  lastName     String
  dateOfBirth  DateTime?
  gender       Gender?
  avatarUrl    String?
  bio          String?
  aadhaarNumber String?  @unique
  panNumber    String?   @unique
  preferredLanguage String @default("en")
  latitude     Float?
  longitude    Float?
  address      String?
  city         String?
  state        String?
  pincode      String?
  country      String    @default("India")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model OAuthAccount {
  id           String   @id @default(cuid())
  userId       String
  provider     String   // "google" | "facebook"
  providerAccountId String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  tokenType    String?
  scope        String?
  idToken      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}


// ==========================================
// RBAC
// ==========================================

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // "complaints:read" | "complaints:write"
  displayName String
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now())

  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ==========================================
// DEPARTMENTS
// ==========================================

model Department {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  logoUrl     String?
  headName    String?
  email       String?
  phone       String?
  address     String?
  isActive    Boolean  @default(true)
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  officers    DepartmentOfficer[]
  services    Service[]
  complaints  Complaint[]
  offices     GovernmentOffice[]

  @@map("departments")
}

model DepartmentOfficer {
  id           String   @id @default(cuid())
  userId       String   @unique
  departmentId String
  designation  String
  employeeId   String?
  isHead       Boolean  @default(false)
  joinedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id])

  @@map("department_officers")
}

// ==========================================
// SERVICES & SCHEMES
// ==========================================

model Service {
  id              String          @id @default(cuid())
  departmentId    String
  name            String
  description     String
  category        ServiceCategory
  eligibility     String?
  requiredDocs    String[]
  fees            Decimal?        @db.Decimal(10, 2)
  processingDays  Int             @default(7)
  maxApplications Int?
  isActive        Boolean         @default(true)
  isOnline        Boolean         @default(true)
  iconUrl         String?
  thumbnailUrl    String?
  formSchema      Json?
  tags            String[]
  // RAG
  embeddingVector Unsupported("vector(1536)")?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  department    Department    @relation(fields: [departmentId], references: [id])
  applications  Application[]
  savedBy       SavedService[]

  @@index([category])
  @@index([isActive])
  @@index([tags])
  @@map("services")
}

model Scheme {
  id              String   @id @default(cuid())
  name            String
  description     String
  benefits        String
  eligibility     String
  requiredDocs    String[]
  applicationUrl  String?
  startDate       DateTime?
  endDate         DateTime?
  budget          Decimal? @db.Decimal(20, 2)
  beneficiaries   Int?
  isActive        Boolean  @default(true)
  tags            String[]
  category        String
  state           String?
  // RAG
  embeddingVector Unsupported("vector(1536)")?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
  @@index([category])
  @@map("schemes")
}

model SavedService {
  userId    String
  serviceId String
  savedAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([userId, serviceId])
  @@map("saved_services")
}

// ==========================================
// APPLICATIONS
// ==========================================

model Application {
  id              String            @id @default(cuid())
  applicationNo   String            @unique @default(cuid())
  userId          String
  serviceId       String
  status          ApplicationStatus @default(DRAFT)
  formData        Json
  submittedAt     DateTime?
  reviewedAt      DateTime?
  completedAt     DateTime?
  reviewedBy      String?
  remarks         String?
  priority        Int               @default(0)
  estimatedDate   DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user            User                  @relation(fields: [userId], references: [id])
  service         Service               @relation(fields: [serviceId], references: [id])
  documents       ApplicationDocument[]
  updates         ApplicationUpdate[]

  @@index([userId])
  @@index([serviceId])
  @@index([status])
  @@index([applicationNo])
  @@map("applications")
}

model ApplicationDocument {
  id            String   @id @default(cuid())
  applicationId String
  documentId    String
  fieldName     String
  createdAt     DateTime @default(now())

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  document      Document    @relation(fields: [documentId], references: [id])

  @@map("application_documents")
}

model ApplicationUpdate {
  id            String            @id @default(cuid())
  applicationId String
  status        ApplicationStatus
  remarks       String?
  updatedBy     String
  createdAt     DateTime          @default(now())

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_updates")
}

// ==========================================
// COMPLAINTS
// ==========================================

model Complaint {
  id            String            @id @default(cuid())
  complaintNo   String            @unique @default(cuid())
  userId        String
  departmentId  String?
  officerId     String?
  title         String
  description   String
  category      String
  subCategory   String?
  priority      ComplaintPriority @default(MEDIUM)
  status        ComplaintStatus   @default(OPEN)
  latitude      Float?
  longitude     Float?
  address       String?
  resolvedAt    DateTime?
  closedAt      DateTime?
  escalatedAt   DateTime?
  dueDate       DateTime?
  satisfactionRating Int?
  satisfactionNote   String?
  isAnonymous   Boolean           @default(false)
  // RAG
  embeddingVector Unsupported("vector(1536)")?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  department    Department?    @relation(fields: [departmentId], references: [id])
  officer       User?          @relation("OfficerComplaints", fields: [officerId], references: [id])
  updates       ComplaintUpdate[]
  media         ComplaintMedia[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([departmentId])
  @@map("complaints")
}

model ComplaintUpdate {
  id          String          @id @default(cuid())
  complaintId String
  status      ComplaintStatus
  message     String
  updatedBy   String
  isPublic    Boolean         @default(true)
  createdAt   DateTime        @default(now())

  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@map("complaint_updates")
}

model ComplaintMedia {
  id          String   @id @default(cuid())
  complaintId String
  url         String
  mimeType    String
  fileName    String
  fileSize    Int
  createdAt   DateTime @default(now())

  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@map("complaint_media")
}

// ==========================================
// DOCUMENTS
// ==========================================

model Document {
  id           String         @id @default(cuid())
  userId       String
  type         DocumentType
  status       DocumentStatus @default(PENDING)
  fileName     String
  fileUrl      String
  fileSize     Int
  mimeType     String
  ocrText      String?
  ocrData      Json?
  isVerified   Boolean        @default(false)
  verifiedBy   String?
  verifiedAt   DateTime?
  expiryDate   DateTime?
  documentNo   String?
  issueDate    DateTime?
  issuerName   String?
  // RAG embedding for document content
  embeddingVector Unsupported("vector(1536)")?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications ApplicationDocument[]

  @@index([userId])
  @@index([type])
  @@index([status])
  @@map("documents")
}

// ==========================================
// AI & CONVERSATIONS
// ==========================================

model Conversation {
  id          String   @id @default(cuid())
  userId      String
  title       String?
  sessionId   String?
  isActive    Boolean  @default(true)
  context     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    Message[]
  aiSession   AISession?

  @@index([userId])
  @@map("conversations")
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  attachments    Json?
  sources        Json?       // RAG source citations
  confidence     Float?
  tokensUsed     Int?
  modelUsed      String?
  isHidden       Boolean     @default(false)
  // Embedding for semantic search on history
  embeddingVector Unsupported("vector(1536)")?
  createdAt      DateTime    @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model AISession {
  id             String   @id @default(cuid())
  userId         String
  conversationId String   @unique
  sessionData    Json     // Working memory, context, preferences
  totalTokens    Int      @default(0)
  lastActivity   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ai_sessions")
}

model AIMemory {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     String
  context   String?
  weight    Float    @default(1.0)
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
  @@map("ai_memory")
}

// ==========================================
// KNOWLEDGE BASE (RAG)
// ==========================================

model KnowledgeDocument {
  id          String   @id @default(cuid())
  title       String
  content     String
  source      String?
  category    String?
  department  String?
  language    String   @default("en")
  isActive    Boolean  @default(true)
  uploadedBy  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chunks      KnowledgeChunk[]

  @@index([category])
  @@index([isActive])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id          String   @id @default(cuid())
  documentId  String
  content     String
  chunkIndex  Int
  tokenCount  Int
  metadata    Json?
  embeddingVector Unsupported("vector(1536)")
  createdAt   DateTime @default(now())

  document    KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("knowledge_chunks")
}

// ==========================================
// NOTIFICATIONS
// ==========================================

model Notification {
  id         String              @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  body       String
  data       Json?
  isRead     Boolean             @default(false)
  readAt     DateTime?
  channel    NotificationChannel @default(IN_APP)
  sentAt     DateTime?
  createdAt  DateTime            @default(now())

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id      String              @id @default(cuid())
  userId  String
  channel NotificationChannel
  type    NotificationType
  enabled Boolean             @default(true)

  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel, type])
  @@map("notification_preferences")
}

// ==========================================
// LOCATIONS
// ==========================================

model GovernmentOffice {
  id            String   @id @default(cuid())
  departmentId  String
  name          String
  address       String
  city          String
  state         String
  pincode       String
  latitude      Float
  longitude     Float
  phone         String?
  email         String?
  openingHours  Json?
  services      String[]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  department    Department @relation(fields: [departmentId], references: [id])

  @@index([latitude, longitude])
  @@map("government_offices")
}

// ==========================================
// FEEDBACK & ANALYTICS
// ==========================================

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "service" | "complaint" | "app" | "officer"
  entityId  String?
  rating    Int
  comment   String?
  tags      String[]
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id])

  @@index([type, entityId])
  @@map("feedback")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  resource   String
  resourceId String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  user       User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  group     String?
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model Language {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  nativeName String
  direction String   @default("ltr")
  isActive  Boolean  @default(true)
  flagEmoji String?

  @@map("languages")
}
